namespace internal {
template <typename>
constexpr std::false_type has_alloc0_h(size_t, long);
template <typename Allocator>
constexpr std::false_type has_realloc_h(typename Allocator::pointer, size_t, long);
template <typename>
constexpr std::false_type has_context_h(long);
template <typename Allocator>
constexpr auto has_alloc0_h(size_t s, int) ->
    decltype(std::declval<Allocator>().allocate_zero(s), std::true_type{});
template <typename Allocator>
constexpr auto has_realloc_h(typename Allocator::pointer p, size_t s, int) ->
    decltype(std::declval<Allocator>().reallocate(p, s), std::true_type{});
template <typename Allocator>
constexpr auto has_context_h(int) -> decltype(std::declval<Allocator>().get_context(), std::true_type{});
template <typename Allocator>
using has_alloc0 = decltype(has_alloc0_h<Allocator>(0, 0));
template <typename Allocator>
using has_realloc = decltype(has_realloc_h<Allocator>(NULL, 0, 0));
template <typename Allocator>
using has_context = decltype(has_context_h<Allocator>(0));

template <typename Allocator>
FORCE_INLINE typename Allocator::pointer alloc0(Allocator &allocator, size_t s,
                                                std::true_type const &, const SourceLocation &loc)
    { return allocator.allocate_zero(s, 0, loc); }
template <typename Allocator>
typename Allocator::pointer alloc0(Allocator &allocator, size_t s,
                                   std::false_type const &, const SourceLocation &loc)
{
    static_assert(!std::is_same<Allocator,Allocator>::value,
                  "no alloc0 (disable the check if you are using stl or customized allocators)");
    auto *res = allocator.allocate(s, 0, loc);
    memset(res, 0, s * sizeof(typename Allocator::value_type));
    return res;
}
template <typename Allocator>
FORCE_INLINE typename Allocator::pointer realloc(Allocator &allocator, typename Allocator::pointer p,
                                    size_t s, std::true_type const &, const SourceLocation &loc)
    { return allocator.reallocate(p, s, loc); }
template <typename Allocator>
typename Allocator::pointer realloc(Allocator &allocator, typename Allocator::pointer p,
                                    size_t s, std::false_type const &, const SourceLocation &loc)
{
    static_assert(!std::is_same<Allocator,Allocator>::value,
                  "no realloc (disable the check if you are using stl or customized allocators)");
    auto *res = allocator.allocate(s, loc);
    memcpy(res, p, s * sizeof(typename Allocator::value_type));
    allocator.deallocate(p, s);
    return res;
}

template <typename Allocator>
FORCE_INLINE MemoryContext get_context(const Allocator &allocator, std::true_type const &)
    { return allocator.get_context(); }
template <typename Allocator>
FORCE_INLINE MemoryContext get_context(const Allocator &allocator, std::false_type const &)
    { return CurrentMemoryContext; }
} /* internal */

template <typename Allocator>
FORCE_INLINE typename Allocator::pointer alloc0(Allocator &allocator, size_t s, MAKE_SOURCE_LOCATION(loc))
    { return internal::alloc0(allocator, s, internal::has_alloc0<Allocator>{}, loc); }
template <typename Allocator>
FORCE_INLINE typename Allocator::pointer realloc(Allocator &allocator, typename Allocator::pointer p,
                                                 size_t s, MAKE_SOURCE_LOCATION(loc))
    { return internal::realloc(allocator, p, s, internal::has_realloc<Allocator>{}, loc); }
template <typename Allocator>
FORCE_INLINE MemoryContext get_context(Allocator &allocator)
    { return internal::get_context(allocator, internal::has_context<Allocator>{}); }
} /* namespace vtl */

